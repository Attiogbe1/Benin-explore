
// backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  VISITEUR
  TOURISTE
  PRESTATAIRE
  ADMIN
}

enum ServiceType {
  HEBERGEMENT
  TRANSPORT
  GUIDE
  ACTIVITE
  RESTAURANT
}

enum ReservationStatus {
  EN_ATTENTE
  CONFIRMEE
  EN_COURS
  TERMINEE
  ANNULEE
  REFUSEE
}

enum SiteCategory {
  HISTORIQUE
  NATUREL
  CULTUREL
  RELIGIEUX
  GASTRONOMIQUE
  PLAGE
  ARTISANAT
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String?
  nom           String
  prenom        String
  avatar        String?
  role          UserRole  @default(TOURISTE)
  langue        String    @default("fr")
  googleId      String?   @unique
  telephone     String?
  pays          String?
  bio           String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  reviews              Review[]
  serviceReviews       ServiceReview[]
  reservations         Reservation[]
  favorites            Favorite[]
  provider             Provider?
  chatSessions         ChatSession[]
  badges               UserBadge[]
  emergencyContacts    EmergencyContact[]
  notifications        Notification[]

  @@map("users")
}

model Region {
  id          String   @id @default(cuid())
  nomFr       String
  nomEn       String
  slug        String   @unique
  description String?
  latitude    Float
  longitude   Float
  sites       TouristSite[]

  @@map("regions")
}

model Category {
  id       String       @id @default(cuid())
  nomFr    String
  nomEn    String
  nomEs    String
  nomDe    String
  slug     String       @unique
  icone    String
  couleur  String
  type     SiteCategory
  sites    TouristSite[]

  @@map("categories")
}

model TouristSite {
  id              String   @id @default(cuid())
  slug            String   @unique

  nomFr           String
  nomEn           String
  nomEs           String
  nomDe           String
  descriptionFr   String   @db.Text
  descriptionEn   String   @db.Text
  descriptionEs   String   @db.Text
  descriptionDe   String   @db.Text
  histoireFr      String?  @db.Text
  histoireEn      String?  @db.Text

  adresse         String
  latitude        Float
  longitude       Float
  horaires        Json?
  tarifs          Json?
  accessibilite   Boolean  @default(true)
  gratuit         Boolean  @default(false)
  enfants         Boolean  @default(true)
  avecGuide       Boolean  @default(false)

  imagesCouverture String[]
  images          String[]
  videoUrl        String?
  audioGuideFr    String?
  audioGuideEn    String?

  regionId        String
  region          Region   @relation(fields: [regionId], references: [id])
  categoryId      String
  category        Category @relation(fields: [categoryId], references: [id])

  noteMoyenne     Float    @default(0)
  nombreAvis      Int      @default(0)
  nombreVues      Int      @default(0)
  popularite      Int      @default(0)

  estActif        Boolean  @default(true)
  estVedette      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  reviews         Review[]
  favorites       Favorite[]

  @@map("tourist_sites")
}

model Provider {
  id              String      @id @default(cuid())
  userId          String      @unique
  user            User        @relation(fields: [userId], references: [id])
  nomEntreprise   String
  descriptionFr   String      @db.Text
  descriptionEn   String?     @db.Text
  telephone       String
  email           String
  adresse         String
  logo            String?
  images          String[]
  siteWeb         String?
  estVerifie      Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  services        Service[]
  reservations    Reservation[]

  @@map("providers")
}

model ServiceReview {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  serviceId     String
  service       Service     @relation(fields: [serviceId], references: [id])
  reservationId String      @unique
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  note          Int
  commentaire   String      @db.Text
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([userId, serviceId])
  @@map("service_reviews")
}

model Service {
  id              String      @id @default(cuid())
  providerId      String
  provider        Provider    @relation(fields: [providerId], references: [id])
  type            ServiceType
  nomFr           String
  nomEn           String
  descriptionFr   String      @db.Text
  descriptionEn   String?     @db.Text
  prix            Float
  devise          String      @default("XOF")
  capacite        Int?
  duree           Int?
  images          String[]
  videoUrl        String?
  disponible      Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  reservations    Reservation[]
  reviews         ServiceReview[]
  noteMoyenne     Float    @default(0)
  nombreAvis      Int      @default(0)

  @@map("services")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  titre     String
  message   String
  lien      String?
  lu        Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("notifications")
}

model Reservation {
  id               String            @id @default(cuid())
  userId           String
  user             User              @relation(fields: [userId], references: [id])
  serviceId        String
  service          Service           @relation(fields: [serviceId], references: [id])
  providerId       String
  provider         Provider          @relation(fields: [providerId], references: [id])
  dateDebut        DateTime
  dateFin          DateTime?
  nombrePersonnes  Int               @default(1)
  statut           ReservationStatus @default(EN_ATTENTE)
  prixTotal        Float
  notes            String?
  methodePaiement  String?
  referencePayment String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  serviceReview    ServiceReview?

  @@map("reservations")
}

model Review {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  siteId      String
  site        TouristSite @relation(fields: [siteId], references: [id])
  note        Int
  commentaire String      @db.Text
  photos      String[]
  estApprouve Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([userId, siteId])
  @@map("reviews")
}

model Favorite {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id])
  siteId    String
  site      TouristSite @relation(fields: [siteId], references: [id])
  createdAt DateTime    @default(now())

  @@unique([userId, siteId])
  @@map("favorites")
}

model ChatSession {
  id        String        @id @default(cuid())
  userId    String?
  user      User?         @relation(fields: [userId], references: [id])
  sessionId String        @unique
  langue    String        @default("fr")
  createdAt DateTime      @default(now())
  messages  ChatMessage[]

  @@map("chat_sessions")
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id])
  role      String
  contenu   String      @db.Text
  createdAt DateTime    @default(now())

  @@map("chat_messages")
}

model Badge {
  id            String      @id @default(cuid())
  nomFr         String
  nomEn         String
  descriptionFr String
  icone         String
  condition     String
  users         UserBadge[]

  @@map("badges")
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  badgeId  String
  badge    Badge    @relation(fields: [badgeId], references: [id])
  obtenuLe DateTime @default(now())

  @@unique([userId, badgeId])
  @@map("user_badges")
}

model EmergencyContact {
  id        String @id @default(cuid())
  userId    String
  user      User   @relation(fields: [userId], references: [id])
  nom       String
  telephone String
  email     String?

  @@map("emergency_contacts")
}

model SecurityAlert {
  id         String   @id @default(cuid())
  regionSlug String?
  messageFr  String
  messageEn  String
  severite   String
  estActive  Boolean  @default(true)
  createdAt  DateTime @default(now())
  expireAt   DateTime?

  @@map("security_alerts")
}

model BlogPost {
  id         String   @id @default(cuid())
  slug       String   @unique
  titreFr    String
  titreEn    String
  contenuFr  String   @db.Text
  contenuEn  String   @db.Text
  imageCover String?
  auteur     String
  categorie  String
  estPublie  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("blog_posts")
}
