# ─── Base de données ────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/benin_explore"

# ─── Serveur ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ─── Authentification ───────────────────────────────────────────────────────────
JWT_SECRET=votre_jwt_secret_tres_long_et_aleatoire_ici
JWT_EXPIRES_IN=7d

# ─── Google OAuth ───────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=votre_google_client_id
GOOGLE_CLIENT_SECRET=votre_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# ─── Anthropic (Chatbot IA) ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-votre_cle_anthropic

# ─── Météo ──────────────────────────────────────────────────────────────────────
OPENWEATHER_API_KEY=votre_cle_openweathermap

# ─── Email (Nodemailer) ─────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre@email.com
SMTP_PASS=votre_mot_de_passe_app

# ─── Upload ─────────────────────────────────────────────────────────────────────
UPLOAD_MAX_SIZE=10485760
UPLOAD_DIR=./uploads

# ─── Web Push (VAPID) ───────────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=votre_vapid_public_key
VAPID_PRIVATE_KEY=votre_vapid_private_key
VAPID_EMAIL=mailto:votre@email.com
